# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/ganatra_clinic

# Long random string used to sign login tokens — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Port the API listens on
PORT=4000

# Comma-separated list of origins allowed to call the API (your web app + mobile app dev URLs)
CORS_ORIGIN=http://localhost:5173

# Where uploaded stationery photos are written in local/dev mode.
# In production, replace src/routes/upload.js with direct-to-S3 signed uploads instead.
UPLOAD_DIR=uploads

# The one special account allowed to self-activate as Admin (via emailed
# OTP) instead of waiting for another admin's approval. Required — if left
# unset, no account can bootstrap as Admin on a fresh database (a clear
# startup warning is logged instead of silently falling back to any
# particular person's identity).
ADMIN_BOOTSTRAP_USER_ID=
ADMIN_BOOTSTRAP_EMAIL=

# Shown in OTP email/SMS text ("Your X verification code is..."). Set this
# to the clinic's name for this deployment.
CLINIC_DISPLAY_NAME=Clinic ERP

# --- OTP delivery (optional) ---
# Leave DEMO_OTP_MODE unset or "true" to skip real sending and just log/return
# the code — good for testing before you've connected a real provider.
# Set DEMO_OTP_MODE=false once the credentials below are filled in for real.
DEMO_OTP_MODE=true

# Email OTP (for the admin bootstrap account) — any SMTP provider works,
# e.g. Gmail (smtp.gmail.com, port 587, an "app password", not your normal one)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SMS OTP (for password resets) — from twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
