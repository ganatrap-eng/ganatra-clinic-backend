{
  "name": "ganatra-clinic-backend",
  "version": "1.0.0",
  "description": "API backend for the Ganatra Clinic ERP",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "psql \"$DATABASE_URL\" -f sql/schema.sql",
    "migrate:permissions": "psql \"$DATABASE_URL\" -f sql/002_permissions.sql",
    "migrate:audit": "psql \"$DATABASE_URL\" -f sql/003_audit_log.sql",
    "migrate:gifts": "psql \"$DATABASE_URL\" -f sql/004_gift_amount.sql",
    "migrate:roles": "psql \"$DATABASE_URL\" -f sql/007_free_text_roles.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.12.0",
    "twilio": "^5.2.2"
  }
}
